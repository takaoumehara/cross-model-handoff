{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "clear|compact|startup",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start-restore-handoff.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/precompact-handoff-gate.sh"
          }
        ]
      }
    ]
  }
}
